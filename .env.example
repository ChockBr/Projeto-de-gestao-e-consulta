# Ports
FRONTEND_PORT=3000
BACKEND_PORT=8080

# Database container
POSTGRES_IMAGE=postgres:16
POSTGRES_DB=realestate
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me

# Backend datasource (container-to-container)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/realestate
SPRING_DATASOURCE_USERNAME=appuser
SPRING_DATASOURCE_PASSWORD=change-me

# JWT
JWT_SECRET=change-me-to-a-secure-key-with-at-least-32-bytes
JWT_EXPIRATION_MS=86400000

# Frontend -> backend base url (baked at build time)
VITE_API_BASE_URL=http://localhost:8080
